generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}





model Attraction {
  id              String           @id @default(cuid())
  title           String
  description     String           @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  attractionItems AttractionItem[]
}

model AttractionItem {
  id            String                @id @default(cuid())
  title         String
  description   String                @db.Text
  mainImageUrl  String
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  attractionId  String
  attraction    Attraction            @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  gallery       AttractionItemImage[]
}

model AttractionItemImage {
  id               String         @id @default(cuid())
  imageUrl         String
  publicId         String
  createdAt        DateTime       @default(now())

  attractionItemId String
  attractionItem   AttractionItem @relation(fields: [attractionItemId], references: [id], onDelete: Cascade)
}





model Culture {
  id           String        @id @default(cuid())
  title        String
  description  String        @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  cultureItems CultureItem[]
}

model CultureItem {
  id           String             @id @default(cuid())
  title        String
  description  String             @db.Text
  mainImageUrl String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  cultureId    String
  culture      Culture            @relation(fields: [cultureId], references: [id], onDelete: Cascade)

  gallery      CultureItemImage[]
}

model CultureItemImage {
  id            String      @id @default(cuid())
  imageUrl      String
  publicId      String
  createdAt     DateTime    @default(now())

  cultureItemId String
  cultureItem   CultureItem @relation(fields: [cultureItemId], references: [id], onDelete: Cascade)
}





model Showcase {
  id            String         @id @default(cuid())
  title         String
  description   String         @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  showcaseItems ShowcaseItem[]
}

model ShowcaseItem {
  id            String              @id @default(cuid())
  title         String
  description   String              @db.Text
  mainImageUrl  String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  showcaseId    String
  showcase      Showcase            @relation(fields: [showcaseId], references: [id], onDelete: Cascade)

  gallery       ShowcaseItemImage[]
}

model ShowcaseItemImage {
  id             String       @id @default(cuid())
  imageUrl       String
  publicId       String
  createdAt      DateTime     @default(now())

  showcaseItemId String
  showcaseItem   ShowcaseItem @relation(fields: [showcaseItemId], references: [id], onDelete: Cascade)
}





model User {
  id        String   @id                // CLERK USER ID
  email     String   @unique
  firstName String
  lastName  String
  role      UserRole @default(USER)

  createdAt DateTime    @default(now())  @db.Timestamptz(3)

  bookings  Booking[]
  payments  Payment[]
  reviews   Review[]
}

enum UserRole {
  USER
  ADMIN
}





model Tour {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  location    String
  price       Float
  duration    Int      // days

  minGuests   Int       @default(1)
  maxGuests   Int       @default(10)

  image       String?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())  @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt       @db.Timestamptz(3)

  bookings    Booking[]
  reviews     Review[]
}





model Booking {
  id                  Int      @id @default(autoincrement())

  userId              String
  user                User     @relation(fields: [userId], references: [id])

  tourId              Int
  tour                Tour     @relation(fields: [tourId], references: [id])

  arrivalDate         DateTime
  checkoutDate        DateTime
  numberOfTravellers  Int

  totalAmount Float

  status              BookingStatus @default(PENDING)

  payment             Payment?

  notes               String?

  createdAt           DateTime @default(now())  @db.Timestamptz(3)
  updatedAt           DateTime @updatedAt       @db.Timestamptz(3)
}

enum BookingStatus {
  PENDING
  ACTIVE
  CONFIRMED
  COMPLETED
  CANCELLED
}





model Payment {
  id            Int           @id @default(autoincrement())

  bookingId     Int           @unique
  booking       Booking       @relation(fields: [bookingId], references: [id])

  userId        String
  user          User          @relation(fields: [userId], references: [id])

  amount        Float
  type          PaymentType

  method        PaymentMethod @default(WEBXPAY)
  status        PaymentStatus @default(PENDING)

  transactionId String?       // WebXPay reference
  gatewayData   Json?         // raw response from WebXPay

  createdAt     DateTime @default(now())  @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt       @db.Timestamptz(3)
}

enum PaymentType {
  FULL
  ADVANCE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  WEBXPAY
}





model Contact {
  id        Int      @id @default(autoincrement())

  name      String
  email     String
  subject   String
  message   String

  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())  @db.Timestamptz(3)
}




model Review {
  id          String   @id @default(cuid())
  rating      Int
  comment     String   @db.Text

  isVisible   Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tourId      Int
  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  @@unique([userId, tourId])
}